/* Test de casos validos e invalidos */

/* === VALIDOS === */

int x;
float y;
string s;

x = 10;
y = 3.14;
s = "hola mundo";

if (x <= 10){
    x = x + 1;
}

while (x > 0){
    x = x - 1;
}

/* operadores relacionales */
if (x == 0){ return; }
if (x != 5){ return; }
if (y >= 1.5){ return; }

/* identificadores validos */
int _a123;
int abc_123;
int ABC;

/* === INVALIDOS === */

/* underscore solo */
int _;

/* doble underscore */
int __abc;

/* numero real sin decimal */
float z;
z = 5.;

/* caracter invalido */
int @var;

/* ! solo */
if (x ! 5){ return; }
